  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<align=\"center\"><color=#FF00FF><size=45><b>CARA BERMAIN</b></size></color></align>\r\n\r\n<align=\"left\"><color=#333333><size=26>\r\n1.
    Pilih <b>Menu Belajar (AR)</b> untuk memindai kartu.\r\n2. Arahkan kamera ke
    <b>Marker Kartu</b> untuk melihat objek 3D.\r\n3. Gunakan <b>Sentuhan Jari</b>
    untuk memutar objek 3D.\r\n4. Pilih <b>Menu Ujian (Quiz)</b> untuk mengasah hafalan
    Kanji N5.\r\n5. Jawab soal sebanyak mungkin untuk mendapat skor terbaik!\r\n</size></color></align>\r\n\r\n<br><align=\"center\"><color=#FF00FF><size=45><b>TEKNOLOGI
    & FITUR</b></size></color></align>\r\n\r\n<align=\"left\"><color=#333333><size=26>\r\nAplikasi
    ini dikembangkan menggunakan <b>Unity Engine</b> dan <b>Vuforia Engine</b> sebagai
    media pembelajaran interaktif berbasis Augmented Reality.\r\n\r\nFitur Utama:\r\n\u2022
    <b>12 Kanji N5 Dasar</b>: Visualisasi 3D Elemen Dasar.\r\n\u2022 <b>Audio Support</b>:
    Cara baca Onyomi & Kunyomi.\r\n\u2022 <b>Interaksi Sentuh</b>: Objek dapat diputar
    360 derajat.\r\n</size></color></align>\r\n\r\n<br><align=\"center\"><color=#FF00FF><size=45><b>SUMBER
    ASET (CREDITS)</b></size></color></align>\r\n\r\n<align=\"center\"><color=#333333><size=26>\r\n<b>Background
    Music (BGM):</b>\r\n\"The Bouncy Pop\" by <b>3KTrack</b>\r\n\u2117 2020 Audiostock
    Inc.\r\n\r\n<b>Sound Effects (SFX):</b>\r\nEffect Stock via <b>soundeffect-lab.info</b>\r\n\r\n<b>Data
    Kanji:</b>\r\nJLPT N5 Vocabulary Resources\r\n</size></color></align>\r\n\r\n<br><align=\"center\"><color=#FF00FF><size=45><b>TENTANG
    PENGEMBANG</b></size></color></align>\r\n\r\n<align=\"center\"><color=#333333><size=26>\r\nDibuat
    oleh:\r\n<size=32><color=#0000FF><b>Faiz Kurniawan</b></color></size> (2255201039)\r\n<size=32><color=#0000FF><b>Saiful
    Irvanda</b></color></size> (2255201064)\r\n<size=32><color=#0000FF><b>Tomi Irawan</b></color></size>
    (2255201049)\r\n\r\nProgram Studi: <b>Ilmu Komputer</b>\r\n<b>Universitas Nahdlatul
    Ulama Blitar</b>\r\n\r\n<size=22>Tugas Akhir Mata Kuliah:\r\n<b>Realitas Virtual
    & Augmentasi</b></size>\r\n\r\n<size=20><color=#888888>\xA9 2026</color></size>\r\n</size></color></align>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: d60b0bac597a5c541bc303bfa910baf0, type: 2}
  m_sharedMaterial: {fileID: 2140474, guid: 8a89fa14b10d46a99122fd4f73fca9a2, type: 2}
